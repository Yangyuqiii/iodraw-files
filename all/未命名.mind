{"root":{"data":{"id":"djv2npu2m9k0","created":1783705019800,"text":"向量数据库"},"children":[{"data":{"id":"djv2nu75j7s0","created":1783705029299,"text":"什么是向量数据库","layout_mind_offset":{"x":-76.50000066797884,"y":-152.50000099363626},"priority":"1"},"children":[]},{"data":{"id":"djv2nzxbceg0","created":1783705041764,"text":"如何工作","layout_mind_offset":{"x":464.9999996220524,"y":107.49999991262496},"expandState":"expand","priority":"2","progress":null,"layout":null},"children":[{"data":{"id":"djv2og9nsxc0","created":1783705077339,"text":"数据向量化","layout_right_offset":{"x":370.74999965395455,"y":40.74999984766987},"layout":null},"children":[{"data":{"id":"djv313n7lyg0","created":1783706068595,"text":"利用训练好的大模型生成向量","layout":null,"layout_right_offset":{"x":343.74999972060345,"y":-1.2499999989839807}},"children":[]}]},{"data":{"id":"djv2ol7rt5c0","created":1783705088109,"text":"构建索引","layout_right_offset":{"x":360.7499996620829,"y":50.74999976503591},"layout":null},"children":[{"data":{"id":"djv31o6q01k0","created":1783706113310,"text":"近似最近邻（ANN）","layout":null,"layout_right_offset":{"x":322.4999997378752,"y":1.2499999989839807}},"children":[{"data":{"id":"djv32ubeouo0","created":1783706205018,"text":"HNSW：构建“智能导航图”","layout":null,"layout_right_offset":{"x":398.74999967589974,"y":3.749999996952056}},"children":[]},{"data":{"id":"djv32z4jik00","created":1783706215487,"text":"IVF：建立“智能目录”","layout":null,"layout_right_offset":{"x":389.9999996830122,"y":23.749999980696202}},"children":[]},{"data":{"id":"djv33l2x55k0","created":1783706263278,"text":"PQ：实施“向量压缩”","layout":null,"layout_right_offset":{"x":367.4999997012999,"y":39.99999996748841}},"children":[]},{"data":{"id":"djv3413s6hs0","created":1783706298159,"text":"IVF_PQ索引","layout":null,"layout_right_offset":{"x":328.74999973279546,"y":39.99999996748852}},"children":[]}]}]},{"data":{"id":"djv2opqybzs0","created":1783705097976,"text":"计算相似度","layout_right_offset":{"x":403.2499996275394,"y":110.24999967197186},"layout":null},"children":[{"data":{"id":"djv3b76ln080","created":1783706859939,"text":"余弦相似度","layout":null,"layout_right_offset":{"x":267.4999997825787,"y":12.499999989840035}},"children":[{"data":{"id":"djv3byrx96g0","created":1783706920001,"text":"场景：处理文本、语义搜索（如RAG问答）","layout":null,"layout_right_offset":{"x":446.2499996372926,"y":-44.99999996342467}},"children":[{"data":{"id":"djv3i4hetww0","created":1783707402612,"text":"用时钟理解，两个向量靠的越近余弦值越接近1，\n就约相似","layout":null,"layout_right_offset":{"x":632.4999994859102,"y":-1.2499999989839807}},"children":[]}]}]},{"data":{"id":"djv3biufc4g0","created":1783706885324,"text":"欧氏距离","layout":null,"layout_right_offset":{"x":261.2499997876587,"y":36.24999997053635}},"children":[{"data":{"id":"djv3c7ev35c0","created":1783706938803,"text":"场景：处理图像、音频或推荐系统（向量模长有意义））","layout":null,"layout_right_offset":{"x":534.9999995651576,"y":-54.999999955296516}},"children":[]}]},{"data":{"id":"djv3boy3vns0","created":1783706898608,"text":"点积","layout":null,"layout_right_offset":{"x":261.2499997876589,"y":42.49999996545648}},"children":[{"data":{"id":"djv3cdb9cog0","created":1783706951646,"text":"追求极致的查询速度使用点积，但前提是必须确保所有向量都已归一化。","layout":null,"layout_right_offset":{"x":573.749999533662,"y":4.999999995936037}},"children":[]}]}]},{"data":{"id":"djv3lnnc02g0","created":1783707679421,"text":"召回率","layout":null,"layout_right_offset":{"x":372.4999996972365,"y":166.24999986487398}},"children":[{"data":{"id":"djv3oq28m7c0","created":1783707919768,"text":"召回率 = 索引实际找到的“真近邻”数量 / 理论上暴力搜索应该找到的“真近邻”总数","layout_right_offset":{"x":699.9999994310465,"y":8.749999992888092}},"children":[]},{"data":{"id":"djv3u3zk0uw0","created":1783708341902,"text":"相邻重叠","layout_right_offset":{"x":298.7499997571788,"y":27.499999977648372}},"children":[{"data":{"id":"djv3u88hphc0","created":1783708351149,"text":"分支主题","layout_right_offset":{"x":236.24999980797838,"y":3.749999996952056}},"children":[]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}